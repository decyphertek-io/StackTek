FROM docker.io/library/caddy:2-builder AS builder

RUN xcaddy build \
    --with github.com/corazawaf/coraza-caddy/v2 \
    --with github.com/corazawaf/coraza-coreruleset

FROM docker.io/library/caddy:2

LABEL org.opencontainers.image.title="StackTek Edge (Caddy + Coraza)" \
      org.opencontainers.image.licenses="AGPL-3.0-or-later OR LicenseRef-Commercial"

COPY --from=builder /usr/bin/caddy /usr/bin/caddy

EXPOSE 443
