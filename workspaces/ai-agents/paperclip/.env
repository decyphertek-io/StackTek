# Paperclip - Environment Configuration
# https://paperclipai-paperclip.mintlify.app/installation

# LLM API Keys (at least one required)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Paperclip Home (data directory inside container)
PAPERCLIP_HOME=/paperclip

# Authentication
PAPERCLIP_SECRET_KEY=your-secret-key-here
