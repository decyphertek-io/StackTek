# OpenClaw — secrets only. Keep this file out of git.

# Gateway auth token (required when binding beyond loopback)
# Generate with: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=

# Model provider API key (set at least one)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...
# OPENROUTER_API_KEY=sk-or-...

# Claude web session (optional)
CLAUDE_AI_SESSION_KEY=
CLAUDE_WEB_SESSION_KEY=
CLAUDE_WEB_COOKIE=

# Channels (only set what you enable)
# TELEGRAM_BOT_TOKEN=
# DISCORD_BOT_TOKEN=
# SLACK_BOT_TOKEN=
# SLACK_APP_TOKEN=

# Tools (optional)
# BRAVE_API_KEY=
# PERPLEXITY_API_KEY=
# FIRECRAWL_API_KEY=
# ELEVENLABS_API_KEY=

# OpenTelemetry (optional)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=
OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=
OTEL_EXPORTER_OTLP_LOGS_ENDPOINT=
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_SERVICE_NAME=
OTEL_SEMCONV_STABILITY_OPT_IN=
OPENCLAW_OTEL_PRELOADED=

# Advanced (optional)
OPENCLAW_ALLOW_INSECURE_PRIVATE_WS=
