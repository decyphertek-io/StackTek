# CrewAI - Environment Configuration
# https://docs.crewai.com/en/installation

# LLM Provider (at least one required)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# CrewAI settings
CREWAI_VERBOSE=true

# ttyd password
TTYD_PASSWORD=crewai

# Default directory for crew projects
CREWAI_HOME=/workspace
