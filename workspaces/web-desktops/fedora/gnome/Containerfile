# Fedora + GNOME + TigerVNC + PipeWire (RHEL-family).

FROM docker.io/library/fedora:latest

ENV LANG=C.UTF-8 \
    LC_ALL=C.UTF-8

RUN dnf install -y dnf-plugins-core \
    && dnf install -y "https://mirrors.rpmfusion.org/free/fedora/rpmfusion-free-release-$(rpm -E %fedora).noarch.rpm" \
       "https://mirrors.rpmfusion.org/nonfree/fedora/rpmfusion-nonfree-release-$(rpm -E %fedora).noarch.rpm" || true \
    && dnf install -y --allowerasing --skip-broken \
        sudo ca-certificates curl wget gnupg2 glibc-langpack-en \
        dbus dbus-x11 \
        tigervnc tigervnc-server-common tigervnc-x11-server \
        @gnome-desktop \
        firefox \
        ffmpeg gstreamer1-plugins-good gstreamer1-plugins-bad-free-extras \
        gstreamer1-plugins-ugly-free gstreamer1-libav \
        pipewire pipewire-pulseaudio wireplumber pulseaudio-utils \
        nano vim git \
        procps-ng iproute iputils hostname \
    && dnf clean all; exit 0

RUN useradd -m -s /bin/bash -u 1000 -o -G wheel,video,plugdev,audio adminotaur \
    && echo "adminotaur ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/adminotaur \
    && mkdir -p /home/adminotaur/.vnc /home/adminotaur/.config/tigervnc \
                /home/adminotaur/data \
    && printf '#!/bin/sh\nexport XKL_XMODMAP_DISABLE=1\nexport XDG_DATA_DIRS="/usr/local/share:/usr/share:/usr/share/gnome"\nunset SESSION_MANAGER\nunset DBUS_SESSION_BUS_ADDRESS\ngnome-session\n' \
        > /home/adminotaur/.vnc/xstartup \
    && printf '#!/bin/sh\nexport XKL_XMODMAP_DISABLE=1\nexport XDG_DATA_DIRS="/usr/local/share:/usr/share:/usr/share/gnome"\nunset SESSION_MANAGER\nunset DBUS_SESSION_BUS_ADDRESS\ngnome-session\n' \
        > /home/adminotaur/.config/tigervnc/xstartup \
    && chmod +x /home/adminotaur/.vnc/xstartup /home/adminotaur/.config/tigervnc/xstartup \
    && printf 'geometry=1920x1080\ndepth=24\nlocalhost=no\n' \
        > /home/adminotaur/.vnc/config \
    && chown -R adminotaur:adminotaur /home/adminotaur

COPY start.sh /start.sh
RUN chmod +x /start.sh

EXPOSE 5901 4713
ENV USER=adminotaur HOME=/home/adminotaur DISPLAY=:1
CMD ["/start.sh"]
