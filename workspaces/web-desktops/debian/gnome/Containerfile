# Debian 13 + GNOME + TigerVNC + PipeWire.
#
# Same contract as the XFCE desktop (noVNC + WebRTC audio on the host); only
# the desktop environment package set and the VNC xstartup differ. GNOME runs
# its session via `gnome-session` over the X server TigerVNC provides.
# Extra GUIs: workspaces/apps/<app-name>/.

FROM docker.io/library/debian:latest

ENV DEBIAN_FRONTEND=noninteractive \
    LANG=C.UTF-8 \
    LC_ALL=C.UTF-8

RUN apt-get update && apt-get install -y --no-install-recommends \
        sudo ca-certificates curl wget gnupg locales \
        dbus dbus-x11 gnome-core gnome-session xserver-xorg \
        tigervnc-standalone-server tigervnc-common \
        pipewire pipewire-pulse pipewire-audio wireplumber \
        pulseaudio-utils \
        firefox-esr nano vim git \
        ffmpeg gstreamer1.0-plugins-good gstreamer1.0-plugins-bad \
        gstreamer1.0-plugins-ugly gstreamer1.0-libav libavcodec-extra \
        net-tools iputils-ping \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

RUN useradd -m -s /bin/bash -u 1000 -G sudo,video,plugdev,audio adminotaur \
    && echo "adminotaur ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/adminotaur \
    && mkdir -p /home/adminotaur/.vnc /home/adminotaur/.config/tigervnc \
                /home/adminotaur/.config/pipewire/pipewire-pulse.conf.d \
                /home/adminotaur/data \
    && printf '#!/bin/sh\nexport XKL_XMODMAP_DISABLE=1\nexport XDG_DATA_DIRS="/usr/local/share:/usr/share:/usr/share/gnome"\nunset SESSION_MANAGER\nunset DBUS_SESSION_BUS_ADDRESS\ngnome-session\n' \
        > /home/adminotaur/.vnc/xstartup \
    && printf '#!/bin/sh\nexport XKL_XMODMAP_DISABLE=1\nexport XDG_DATA_DIRS="/usr/local/share:/usr/share:/usr/share/gnome"\nunset SESSION_MANAGER\nunset DBUS_SESSION_BUS_ADDRESS\ngnome-session\n' \
        > /home/adminotaur/.config/tigervnc/xstartup \
    && chmod +x /home/adminotaur/.vnc/xstartup /home/adminotaur/.config/tigervnc/xstartup \
    && printf 'geometry=1920x1080\ndepth=24\nlocalhost=no\n' \
        > /home/adminotaur/.vnc/config \
    && chown -R adminotaur:adminotaur /home/adminotaur

COPY start.sh /start.sh
RUN chmod +x /start.sh

EXPOSE 5901 4713
ENV USER=adminotaur HOME=/home/adminotaur DISPLAY=:1
CMD ["/start.sh"]
